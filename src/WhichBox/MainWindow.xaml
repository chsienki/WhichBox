<Window
    x:Class="WhichBox.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WhichBox">

    <Grid x:Name="Root"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <!-- Content layer: captured by VisualSurface, container hidden from display -->
        <Grid x:Name="ContentHost">
            <Border x:Name="LabelBorder"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <TextBlock x:Name="MachineNameText"
                               FontSize="22"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                    <!-- Update indicator dot, top-right corner -->
                    <Ellipse x:Name="UpdateDot"
                             Width="8" Height="8"
                             Fill="#FF4444"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,2,3,0"
                             Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
        <!-- Composition output: SpriteVisual with opacity mask is placed here -->
        <Canvas x:Name="MaskHost"/>
    </Grid>
</Window>
